  "categoryGroups": {
    "metrics": {
      "title": "指標"
    },
    "insights": {
      "title": "深入分析",
      "description": "你也可以前往 Chrome 開發人員工具的「效能」面板查看這些深入分析結果。只要[記錄追蹤記錄](https://developer.chrome.com/docs/devtools/performance/reference)，即可查看更詳細的資訊。"
    },
    "diagnostics": {
      "title": "診斷",
      "description": "進一步瞭解應用程式的效能。這些數字不會[直接影響](https://developer.chrome.com/docs/lighthouse/performance/performance-scoring/)「效能」分數。"
    },
    "a11y-best-practices": {
      "title": "最佳做法",
      "description": "這些稽核項目會提供常見的無障礙功能最佳做法。"
    },
    "a11y-color-contrast": {
      "title": "對比",
      "description": "這些稽核建議有助於提高內容的易讀性。"
    },
    "a11y-names-labels": {
      "title": "名稱和標籤",
      "description": "這些稽核建議可協助提高應用程式中的控制項語義品質。這或許能改善輔助技術 (例如螢幕閱讀器) 的使用體驗。"
    },
    "a11y-navigation": {
      "title": "瀏覽",
      "description": "你可以根據這些資訊來改善應用程式的鍵盤瀏覽操作方式。"
    },
    "a11y-aria": {
      "title": "ARIA",
      "description": "這些稽核建議可協助改善 ARIA 在應用程式中的使用情形，進而讓輔助技術 (例如螢幕閱讀器) 的使用體驗更上一層樓。"
    },
    "a11y-language": {
      "title": "國際化和本地化",
      "description": "你可以根據這些稽核建議做出改善，讓其他地區的使用者更容易理解你的內容。"
    },
    "a11y-audio-video": {
      "title": "音訊和影片",
      "description": "你可以根據這些資訊判斷是否要提供用來替代音訊和影片的內容。這或許能改善聽障或視障人士的使用體驗。"
    },
    "a11y-tables-lists": {
      "title": "表格和清單",
      "description": "請參考這些建議事項，讓使用者能夠更容易藉由輔助技術 (例如螢幕閱讀器) 來閱讀表格或清單資料。"
    },
    "seo-mobile": {
      "title": "適合透過行動裝置瀏覽",
      "description": "請確認你的網頁適合在行動裝置上瀏覽，這樣使用者不須撥動雙指或縮放螢幕即可閱讀網頁內容。[瞭解如何打造適合在行動裝置上瀏覽的網頁](https://developers.google.com/search/mobile-sites/)。"
    },
    "seo-content": {
      "title": "內容最佳做法",
      "description": "請設定適當的 HTML 格式，讓檢索器更容易辨識你的應用程式內容。"
    },
    "seo-crawl": {
      "title": "檢索及建立索引",
      "description": "檢索器需要存取你的應用程式，才能將網站顯示在搜尋結果中。"
    },
    "best-practices-trust-safety": {
      "title": "信任與安全性"
    },
    "best-practices-ux": {
      "title": "使用者體驗"
    },
    "best-practices-browser-compat": {
      "title": "瀏覽器相容性"
    },
    "best-practices-general": {
      "title": "一般"
    },
    "hidden": {
      "title": ""
    }
  },
